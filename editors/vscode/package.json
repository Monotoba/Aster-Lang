{
  "name": "aster-lang",
  "displayName": "Aster Language",
  "description": "Syntax highlighting, diagnostics, and language server support for the Aster programming language.",
  "version": "0.1.0",
  "publisher": "aster-lang",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/aster-lang/aster-lang"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "aster",
        "aliases": ["Aster", "aster"],
        "extensions": [".aster"],
        "configuration": "./language-configuration/aster.json"
      }
    ],
    "grammars": [
      {
        "language": "aster",
        "scopeName": "source.aster",
        "path": "./syntaxes/aster.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Aster",
      "properties": {
        "aster.serverPath": {
          "type": "string",
          "default": "aster",
          "description": "Path to the `aster` executable. Defaults to `aster` on PATH."
        },
        "aster.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Log LSP messages between the extension and the language server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.24.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0"
  }
}
