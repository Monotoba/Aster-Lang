{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(fn|if|else|while|for|match)\\b.*:\\s*$",
    "decreaseIndentPattern": "^\\s*(return|break|continue)\\b"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*(fn|if|else|while|for|match)\\b.*:\\s*$",
      "action": {
        "indentAction": "indent"
      }
    }
  ]
}
